---
import { Image } from "astro:assets";

const { src, parallaxSpeed, ...attrs } = Astro.props;
---

<Image 
    src={src} 
    alt=""
    class="absolute bottom-0 select-none left-1/2 w-[300vw] max-w-none -translate-x-1/2 md:left-0 md:w-full md:max-w-full md:translate-x-0"
    loading="eager"
    decoding="auto"
    draggable="false"
    data-parallax-speed={parallaxSpeed}
    {...attrs} />
