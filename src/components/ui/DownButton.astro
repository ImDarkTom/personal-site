---
import { Icon } from "astro-icon/components";
---

<a
    id="down-arrow"
    href="#about"
    aria-label="Scroll down to about section"
    class="fixed bottom-32 left-1/2 -translate-x-1/2 size-12 rounded-full bg-olive-300 flex items-center justify-center cursor-pointer hover:scale-110 active:scale-95 shadow-lg shadow-olive-950/40 z-10">
    <Icon name="mdi:arrow-down" class="text-olive-950 size-6" />
</a>

<style>
    #down-arrow {
        opacity: 1;
        transition: opacity 0.2s ease-in-out, scale 0.2s ease-in-out;
    }

    #down-arrow.fade-out {
        opacity: 0;
        pointer-events: none;
    }
</style>

<script>
    const downArrow = document.querySelector('#down-arrow');

    window.addEventListener('scroll', () => {
        if (!downArrow) return;

        if (window.scrollY > 100) {
            downArrow.classList.add('fade-out');
        } else {
            downArrow.classList.remove('fade-out');
        }
    }, { passive: true });
</script>
