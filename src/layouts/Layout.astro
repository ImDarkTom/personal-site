---
import { Font } from 'astro:assets'
import '../styles/global.css'

import Analytics from '@vercel/analytics/astro'
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Thomas Malinovsky</title>

		<meta name="description" content="Hi, I'm a UX-oriented full-stack developer based in Dublin, Ireland.">
		<meta name="author" content="Thomas Malinovsky">
		<meta name="robots" content="index, follow">
		<meta name="theme-color" content="#31372b">

		<link rel="canonical" href="https://malinovsky.dev">

		<meta name="og:type" content="website">
		<meta name="og:site_name" content="Thomas Malinovsky">
		<meta name="og:title" content="Thomas Malinovsky">
		<meta name="og:description" content="Hi, I'm a UX-oriented full-stack developer based in Dublin, Ireland.">
		<meta name="og:url" content="https://malinovsky.dev">
		<meta name="og:image" content="https://malinovsky.dev/favicon.png">

		<meta name="twitter:card" content="summary">
		<meta name="twitter:creator" content="@ImDarkTom">
		<meta name="twitter:title" content="Thomas Malinovsky">
		<meta name="twitter:description" content="Hi, I'm a UX-oriented full-stack developer based in Dublin, Ireland.">
		<meta name="twitter:image" content="https://malinovsky.dev/favicon.png">
		
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/svg+xml" href="/favicon.ico" />
		<link rel="apple-touch-icon" href="/favicon.svg">
		<link rel="mask-icon" href="/favicon.svg" color="#e4d7ab">

		<meta name="generator" content={Astro.generator} />
		<Font cssVariable='--font-inter' preload />
		<Analytics />
	</head>
	<body class="bg-olive-900 text-cream-100">
		<slot />
	</body>
</html>
